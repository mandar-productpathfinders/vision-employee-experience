# =============================================================================
# Vision Enterprise — UC2 Employee Experience — environment variables
# Copy to `.env` and fill in your API keys before running `docker compose up`.
# =============================================================================

# ---- Database --------------------------------------------------------------
POSTGRES_USER=visionuser
POSTGRES_PASSWORD=visionpass
POSTGRES_DB=vision_employee

# ---- PII encryption (used by onboarding-api to encrypt PAN, bank account, IFSC at rest)
# Change this to a strong random value before any production or real-data use.
DB_ENCRYPTION_KEY=change-me-before-production

# ---- Model provider (matches UC1's one-variable model-switch story) --------
# Set to "anthropic" or "openai"
MODEL_PROVIDER=anthropic

# ---- Anthropic -------------------------------------------------------------
ANTHROPIC_API_KEY=ant-api03
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- OpenAI ----------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ---- Redis -----------------------------------------------------------------
# Password for the Redis instance. All services read this at startup.
# Change to a strong random value before any production or real-data use.
REDIS_PASSWORD=change-me-redis

# ---- Zero-data-retention (Anthropic) ---------------------------------------
# The ZDR beta header is already wired in agent/lib/provider.js.
# ZDR must also be enabled at the org level — contact Anthropic support.
# For OpenAI, store:false is already set per-request in provider.js.
